{
	"info": {
		"_postman_id": "respire-web-api-v1",
		"name": "RespireWeb API",
		"description": "API collection for testing RespireWeb backend",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login Patient",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"login\",\n    \"email\": \"testpatient@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"patient\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users.php",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users.php"
							]
						}
					}
				},
				{
					"name": "Login Doctor",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"action\": \"login\",\n    \"email\": \"testdoctor@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"doctor\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users.php",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users.php"
							]
						}
					}
				}
			]
		},
		{
			"name": "Data Fetching",
			"item": [
				{
					"name": "Get Vitals (User 1)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vitals.php?user_id=1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"vitals.php"
							],
							"query": [
								{
									"key": "user_id",
									"value": "1"
								}
							]
						}
					}
				},
				{
					"name": "Get Doctors List",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users.php?role=doctor",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users.php"
							],
							"query": [
								{
									"key": "role",
									"value": "doctor"
								}
							]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://180.235.121.245/2026JanMarch/respireai/api/",
			"type": "string"
		}
	]
}
